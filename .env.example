# BookMe — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit it.
# This file (.env.example) is safe to commit.

# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Pooled connection URL — used by the app at runtime (goes through PgBouncer)
DATABASE_URL=""

# Direct connection URL — used by Prisma migrations only (bypasses PgBouncer)
# In Neon: Settings → Connection string → select "Direct connection"
DIRECT_URL=""

# ─── NextAuth.js ───────────────────────────────────────────────────────────────
# Full URL of this application
# Development: http://localhost:3000
# Production:  https://yourdomain.com
NEXTAUTH_URL=""

# Random secret for signing JWT session tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Flutterwave (Payment Provider) ───────────────────────────────────────────
# Dashboard: https://dashboard.flutterwave.com/dashboard/settings/apis
# Use test keys (FLWPUBK_TEST_... / FLWSECK_TEST_...) in development
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""

# Webhook secret hash — set this in Flutterwave dashboard under Webhooks
# Used to verify the signature of incoming webhook payloads
# Must match exactly what you set in Flutterwave → Settings → Webhooks → Secret Hash
FLUTTERWAVE_SECRET_HASH=""

# ─── Resend (Transactional Email) ──────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=""

# ─── Application ───────────────────────────────────────────────────────────────
# Public base URL — used in email links and Flutterwave redirect URLs
# Must be accessible from the internet in production (not localhost)
NEXT_PUBLIC_APP_URL=""

# ─── Cloudinary (Media Storage) ────────────────────────────────────────────────
# Dashboard: https://console.cloudinary.com
# Used for vendor portfolio images and profile photos
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
